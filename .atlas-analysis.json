  "keyFeatures": [
    "Autocompletion with snippet and argument placeholder support",
    "Goto definition, declaration, and type definition",
    "Find all references and rename symbol",
    "Hover documentation with Markdown support",
    "Semantic token highlighting",
    "Inlay hints for variable types and parameter names",
    "Code actions and auto-fix on save",
    "Build-on-save diagnostics with Zig's build system",
    "Document symbols and workspace symbol search",
    "Code folding and selection ranges",
    "Signature help",
    "Cross-platform support (Linux, macOS, Windows, WASI)"
  ],
  "publicApiSurface": [
    "zls (binary)",
    "zls help",
    "zls version",
    "zls env",
    "--config-path [path]",
    "--log-file [path]",
    "--log-level [err|warn|info|debug]",
    "--enable-stderr-logs",
    "--disable-lsp-logs",
    "zls.json (configuration file)",
    "enable_snippets",
    "enable_argument_placeholders",
    "enable_build_on_save",
    "build_on_save_args",
    "semantic_tokens",
    "inlay_hints_show_variable_type_hints",
    "inlay_hints_show_parameter_name",
    "warn_style",
    "zig_exe_path",
    "zig_lib_path"
  ]
